# ── MongoDB ───────────────────────────────────────────────────────────────────
# Railway inyecta MONGODB_URL si usas su plugin de Mongo; si no, usa tu Atlas URI
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=orqo

# ── Puertos ───────────────────────────────────────────────────────────────────
# Railway inyecta PORT automáticamente para el servicio público (webhook)
PORT=3001
MANAGEMENT_PORT=3002
HEALTH_PORT=3101

# ── WhatsApp / Meta ────────────────────────────────────────────────────────────
# Token que configuras en Meta Business Console → Webhooks (nivel plataforma)
WHATSAPP_VERIFY_TOKEN=orqo-dev-token
# NOTA: WHATSAPP_TOKEN y WHATSAPP_PHONE_ID ya NO se usan aquí.
# Las credenciales de canal (WhatsApp, Instagram, Facebook) se configuran
# por workspace a través de la Management API:
#   PUT /workspaces/:id/channels/whatsapp  { phoneNumberId, accessToken }
#   PUT /workspaces/:id/channels/instagram { igAccountId, accessToken }
#   PUT /workspaces/:id/channels/facebook  { pageId, accessToken }
# Los tokens se almacenan cifrados (AES-256-GCM) en MongoDB.

# ── LLM providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Clave de cifrado AES-256-GCM para keys de proveedores (hex de 64 chars = 32 bytes)
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ORQO_ENCRYPTION_KEY=

# ── Cola de mensajes ───────────────────────────────────────────────────────────
INBOUND_QUEUE_MAX_ATTEMPTS=4
INBOUND_QUEUE_LEASE_MS=30000
INBOUND_QUEUE_RETRY_BASE_MS=1000
INBOUND_WORKER_POLL_MS=250

# ── Seguridad interna ──────────────────────────────────────────────────────────
# Debe coincidir con CORE_INTERNAL_SECRET en el dashboard (.env.local)
CORE_INTERNAL_SECRET=cambia-esto-en-produccion

# ── Entorno ────────────────────────────────────────────────────────────────────
NODE_ENV=production
