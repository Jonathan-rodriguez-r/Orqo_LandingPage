{
  "name": "@orqo/core",
  "version": "0.1.0",
  "description": "Core de orquestacion de ORQO",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "start:management": "node dist/entrypoints/management.js",
    "dev": "tsx watch src/entrypoints/webhook.ts",
    "dev:management": "tsx watch src/entrypoints/management.ts",
    "dev:health": "tsx watch src/entrypoints/health.ts",
    "test": "jest --passWithNoTests --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.31.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "mongodb": "^7.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.3",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
