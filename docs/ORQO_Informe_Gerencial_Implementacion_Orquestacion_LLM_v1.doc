<div class="cover">
  <h1>ORQO</h1>
  <p class="cover-subtitle">Informe Gerencial de Implementación<br>Arquitectura Omnicanal + Orquestación de LLMs</p>

  <p class="meta">
    <strong>Versión:</strong> 1.0 &nbsp;|&nbsp;
    <strong>Fecha:</strong> 31 de marzo de 2026 &nbsp;|&nbsp;
