<div class="cover">
  <h1 style="font-size:32pt; border:none; text-align:center;">ORQO</h1>
  <p style="font-size:14pt; color:#555555; margin:0;">Documento de Arquitectura y Estado del Proyecto</p>
  <p class="meta" style="margin-top:10pt;">Versión 0.9 &nbsp;|&nbsp; 30 de marzo de 2026 &nbsp;|&nbsp; Bacata Digital Media</p>
